{
  "manifest_version": 3,
  "name": "Sample Cases Copier",
  "version": "1.0",
  "description": "Save Codeforces/AtCoder test samples to a file.",
  "permissions": ["downloads"],
  "host_permissions": [
    "*://codeforces.com/*",
    "*://*.codeforces.com/*",
    "*://atcoder.jp/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://codeforces.com/problemset/problem/*/*",
        "*://codeforces.com/contest/*/problem/*",
        "*://*.codeforces.com/problemset/problem/*/*",
        "*://*.codeforces.com/contest/*/problem/*",
        "*://atcoder.jp/contests/*/tasks/*",
        "*://codeforces.com/gym/*/problem/*",
        "*://*.codeforces.com/gym/*/problem/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ], 
  "browser_specific_settings": {
    "gecko": {
      "id": "sample-copier@karim",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
